# ── Channel ───────────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
# TELEGRAM_CHANNEL_ID=telegram
ALLOWED_USER_IDS=

# ── Agent ────────────────────────────────────────────────────────────────────
# RUNTIME_TYPE: cli | session-claude-sdk | session-claude | session-gemini | session-copilot
RUNTIME_TYPE=cli
RUNTIME_COMMAND=claude --print
RUNTIME_WORKING_DIR=
RUNTIME_TIMEOUT_MS=120000
DEFAULT_AGENT=default

# ── Claude CLI options (for cli runtime) ──────────────────────────────────────
# Model: sonnet, opus, or full model ID (e.g. claude-sonnet-4-6)
# CLAUDE_MODEL=sonnet
#
# System prompt: appended to Claude's default system prompt
# SYSTEM_PROMPT=You are a helpful Telegram assistant.
#
# Permission mode: plan | auto | bypassPermissions
# PERMISSION_MODE=auto
#
# Tool control (comma-separated):
# ALLOWED_TOOLS=Bash(git *),Read
# DISALLOWED_TOOLS=Write,Edit
#
# Limits:
# MAX_TURNS=10
# MAX_BUDGET_USD=5.00
#
# Output format: text | json | stream-json
# OUTPUT_FORMAT=text
#
# Skip auto-discovery of hooks, MCP servers, CLAUDE.md for faster startup
# BARE=true

# ── Claude SDK options (only for session-claude-sdk runtime) ──────────────────
# ANTHROPIC_API_KEY=

# ── Long-term Memory ────────────────────────────────────────────────────────
# Set MEMORY_CHAT_ID to enable. Bot must be admin of the target chat.
# Accepts @username (e.g., @my_agent_memory) or numeric ID.
# MEMORY_CHAT_ID=@my_agent_memory
# MEMORY_TOPIC_ID=
# Extraction auto-detects ANTHROPIC_API_KEY or OPENAI_BASE_URL + OPENAI_API_KEY.
# For OpenRouter: OPENAI_BASE_URL=https://openrouter.ai/api/v1
# MEMORY_LLM_MODEL=                  # override default extraction model

# ── General ──────────────────────────────────────────────────────────────────
LOG_LEVEL=info
# DATA_DIR=                             # defaults to /data when it exists (Docker/Railway)
