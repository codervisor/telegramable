# ── Channel ───────────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
# TELEGRAM_CHANNEL_ID=telegram
ALLOWED_USER_IDS=

# ── Agent ────────────────────────────────────────────────────────────────────
# RUNTIME_TYPE: cli | session-claude-sdk | session-claude | session-gemini | session-copilot
RUNTIME_TYPE=session-claude-sdk
RUNTIME_COMMAND=
RUNTIME_WORKING_DIR=
RUNTIME_TIMEOUT_MS=120000
DEFAULT_AGENT=default

# ── Claude SDK options (for session-claude-sdk runtime) ───────────────────────
ANTHROPIC_API_KEY=
# CLAUDE_MODEL=claude-sonnet-4-20250514
# SYSTEM_PROMPT=
# ALLOWED_TOOLS=
# MAX_BUDGET_USD=

# ── General ──────────────────────────────────────────────────────────────────
LOG_LEVEL=info
